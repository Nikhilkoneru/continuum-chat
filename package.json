{
  "name": "continuum-chat",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev:client": "pnpm --filter client start",
    "dev:client:web": "pnpm --filter client web",
    "dev:daemon": "cargo run --manifest-path apps/daemon/Cargo.toml --bin continuum -- daemon run",
    "build:web": "pnpm --filter client export:web",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint"
  }
}
